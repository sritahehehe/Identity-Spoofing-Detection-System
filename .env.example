# SocietyGuard Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to git.

# HMAC secret for QR code signature verification (use a long random string)
HMAC_SECRET=your-secret-key-here

# Session middleware secret (use a long random string)
SESSION_SECRET_KEY=your-session-secret-here

# Email / SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-gmail-app-password-here
